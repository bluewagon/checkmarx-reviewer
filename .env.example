# Checkmarx One connection
# API key = a Checkmarx One API key (an OAuth refresh token) created under
# Account Settings -> API Keys.
CX_APIKEY=

# API base URL for your region, no trailing slash. Examples:
#   US   https://ast.checkmarx.net
#   US2  https://us.ast.checkmarx.net
#   EU   https://eu.ast.checkmarx.net
#   EU2  https://eu-2.ast.checkmarx.net
CX_BASE_URI=https://us.ast.checkmarx.net

# Your Checkmarx One tenant name (used for the auth realm).
CX_TENANT=

# On-prem Bitbucket (Data Center/Server) HTTP access token, used to shallow-clone
# the repo when --repo-path is given as a Bitbucket clone or browse URL instead of
# a local path. Sent as an "Authorization: Bearer <token>" header. Leave unset when
# --repo-path is a local directory.
CX_BITBUCKET_TOKEN=

# --- AI agent (optional; flags override these) ---
# Which agent to use: claude | copilot | anthropic   (--agent)
#   claude/copilot drive the respective CLIs; anthropic calls the Anthropic API
#   directly (no CLI needed) and authenticates via ANTHROPIC_API_KEY below.
# CX_AI_AGENT=claude
# Anthropic API key, used only by the anthropic agent (other standard Anthropic
# SDK credential sources also work if this is unset).
# ANTHROPIC_API_KEY=
# Model id passed to the agent; leave unset to use the agent's default (--model)
# (the anthropic agent defaults to claude-opus-4-8)
# CX_AI_MODEL=
# Override the agent binary name/path (--agent-bin)
# CX_AI_AGENT_BIN=
# Findings reviewed per agent invocation; higher saves tokens (--batch-size)
# CX_AI_BATCH_SIZE=20
# Max findings/batches processed in parallel — history fetches, agent calls, and
# predicate posts (--concurrency). Higher = faster on large scans; 1 = fully
# sequential. Note: with concurrency > 1 the cost limit becomes approximate.
# CX_CONCURRENCY=4
# Stop the run once cumulative AI cost (USD) exceeds this; 0/unset = no limit
# (--cost-limit). Enforced for agents that report cost: the claude CLI (reports
# its own) and the anthropic API agent (computed from token usage).
# CX_AI_COST_LIMIT=0
# Re-review findings already triaged by this tool instead of skipping them
# (--re-triage).
# CX_RETRIAGE=false
# Maximum findings to review per run; 0/unset = no limit (--limit). New findings
# are selected before re-triaged ones.
# CX_LIMIT=0
# Let the agent read/search the repo for extra context instead of only the
# inlined snippets; better for thin-context findings but slower (--agentic-source).
# CX_AI_AGENTIC_SOURCE=false
# Enable debug logging: HTTP requests, agent invocations, and full error causes
# (--verbose).
# CX_VERBOSE=false
# Directory for per-run diagnostics (--log-dir): a JSONL debug log plus raw
# Checkmarx API response bodies, AI prompts, and AI output. Captured at debug
# level regardless of CX_VERBOSE. Set to "off" to disable. Note: dumps include
# source code snippets from the reviewed repo.
# CX_LOG_DIR=logs

# NOTE: for the claude/copilot agents, model authentication is handled by the
# agent CLI itself — make sure `claude` (Claude Code) or `copilot` (GitHub
# Copilot CLI) is installed and already logged in before running. The anthropic
# agent needs no CLI; it uses ANTHROPIC_API_KEY above.
