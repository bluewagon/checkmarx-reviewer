# Checkmarx One connection
# API key = a Checkmarx One API key (an OAuth refresh token) created under
# Account Settings -> API Keys.
CX_APIKEY=

# API base URL for your region, no trailing slash. Examples:
#   US   https://ast.checkmarx.net
#   US2  https://us.ast.checkmarx.net
#   EU   https://eu.ast.checkmarx.net
#   EU2  https://eu-2.ast.checkmarx.net
CX_BASE_URI=https://us.ast.checkmarx.net

# Your Checkmarx One tenant name (used for the auth realm).
CX_TENANT=

# --- AI agent (optional; flags override these) ---
# Which agent CLI to drive: claude | copilot   (--agent)
# CX_AI_AGENT=claude
# Model id passed to the agent; leave unset to use the agent's default (--model)
# CX_AI_MODEL=
# Override the agent binary name/path (--agent-bin)
# CX_AI_AGENT_BIN=
# Findings reviewed per agent invocation; higher saves tokens (--batch-size)
# CX_AI_BATCH_SIZE=10
# Stop the run once cumulative AI cost (USD) exceeds this; 0/unset = no limit
# (--cost-limit). Only enforced for the Claude agent, which reports its own cost.
# CX_AI_COST_LIMIT=0

# NOTE: authentication for the AI model is handled by the agent CLI itself, not
# this tool. Make sure `claude` (Claude Code) or `copilot` (GitHub Copilot CLI)
# is installed and already logged in before running.
